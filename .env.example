# ---- Nebius Token Factory (LLM + multimodal vision) ----
# Get your key from https://studio.nebius.ai  (you get $100 credit at the event)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# A vision-capable model. Confirm exact name in the Nebius model list at the event.
NEBIUS_VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct

# ---- Vapi (voice) ----
# Dashboard: https://dashboard.vapi.ai  (you get $50 voice credit)
VAPI_API_KEY=
# The phone number ID Vapi gives you after you buy/import a number in the dashboard.
VAPI_PHONE_NUMBER_ID=
# Public URL where Vapi sends call events. Use an ngrok/tunnel URL during the hack.
# e.g. https://your-tunnel.ngrok-free.app/api/vapi/webhook
VAPI_WEBHOOK_URL=

# ---- Insforge (backend / DB) ----
# Hosted: https://insforge.dev  (you get $25 backend credit)
INSFORGE_BASE_URL=
INSFORGE_API_KEY=

# ---- Demo controls ----
# THE SAFE DEMO NUMBER. Point this at YOUR OWN test line / a teammate playing
# "the billing department" so the live call is repeatable. Do NOT cold-call a
# real insurer on stage. E.164 format, e.g. +14155551234
DEMO_TARGET_NUMBER=

PORT=3000
